# Stage 1: build the binary
FROM golang:1.25-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN go build -o server ./cmd/main.go

# Stage 2: minimal runtime image
FROM alpine:latest AS runner

WORKDIR /app

COPY --from=builder /app/server .

EXPOSE 8080

CMD ["./server"]
